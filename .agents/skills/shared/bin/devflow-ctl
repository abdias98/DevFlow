#!/usr/bin/env bash
# devflow-ctl — Deterministic enforcement CLI for the DevFlow framework.
#
# Agents invoke this script at gate transitions instead of self-verifying
# session state. All checks are binary (exit codes), so the result is
# incontestable regardless of which editor or model is driving the session.
#
# Session state lives in the YAML frontmatter of:
#   docs/devflow/session/{slug}/phase-state.md
# (override the root with DEVFLOW_SESSION_ROOT)
#
# Exit codes: 0 = check passed / action done
#             1 = check FAILED (gate closed, scope violation, limit exceeded)
#             2 = usage or state error (missing session, bad arguments)
#
# Usage: devflow-ctl <command> [args] [--slug <slug>]
#
#   init --mode <m> --slug <s> [--scope <glob>]...   Create session + acquire lock
#   status                                           Print session summary
#   phase get | set <N>                              Read / record current phase
#   gate check <name>                                Exit 1 unless gate is open
#   gate set <name> <value>                          Validated state transition
#   scope check <file>                               Exit 1 if file outside scope
#   scope add <glob>                                 Append a glob to the scope
#   iterate <loop> [--max <N>]                       Increment loop counter; exit 1 over limit
#   lock check | acquire <agent> [--force] | release Manage the session lock
#   config set <key> <value> | get <key>             Session settings (branch, pair_mode, mode, phase, rigor)
#   checkpoint set <name> <sha> | get <name>         Record / read rollback SHAs
#   artifacts check <type> <path>                    Validate required sections
#   capabilities [get <key>]                         Print environment capabilities (from .devflow-environment)
#   knowledge list                                   List entries in the knowledge base
#   knowledge add <file>                             Add a knowledge base entry from a file
#   sessions                                         List all active DevFlow sessions with phase and state
#   clean [--force]                                  Remove stale sessions (unlocked >30 min, or all with --force)
#   scan [secrets|sca|sast|all]                      Deterministic security scan (exit 1 on findings)
#
# Gates:    validation (pending|passed|blocked|accepted-risks)
#           confirmation, plan_approval (pending|approved|rejected)
# Loops:    implement_review, implement_debug (max 3); plan_revision,
#           validation_brainstorm (max 2). DEVFLOW_MAX_ITERATIONS overrides all.

set -euo pipefail

SESSION_ROOT="${DEVFLOW_SESSION_ROOT:-docs/devflow/session}"
SCHEMA_VERSION=1
STALE_LOCK_MINUTES=30

# ── Output helpers ────────────────────────────────────────────────────────────

ok()   { echo "[devflow-ctl] OK: $*"; }
fail() { echo "[devflow-ctl] FAIL: $*" >&2; exit 1; }
die()  { echo "[devflow-ctl] ERROR: $*" >&2; exit 2; }

# A slug names a directory under SESSION_ROOT and is interpolated into paths.
# Reject path separators, traversal, and shell metacharacters so a crafted
# --slug can never escape SESSION_ROOT or reach a shell context.
validate_slug() {
  local s="$1"
  case "$s" in
    */*|*..*) die "invalid slug '$s' — '/' and '..' are not allowed (path traversal)" ;;
  esac
  [[ "$s" =~ ^[A-Za-z0-9][A-Za-z0-9._-]*$ ]] \
    || die "invalid slug '$s' — must start alphanumeric; allowed chars: letters, digits, '.', '_', '-'"
}

now_iso() { date -u +%Y-%m-%dT%H:%M:%SZ; }

# Convert ISO-8601 UTC timestamp to epoch seconds (GNU date, then BSD fallback).
to_epoch() {
  local ts="$1"
  date -d "$ts" +%s 2>/dev/null \
    || date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts" +%s 2>/dev/null \
    || echo 0
}

# ── Session resolution ────────────────────────────────────────────────────────

SLUG=""
STATE_FILE=""

# Extract a global --slug flag from anywhere in the argument list.
ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --slug) SLUG="${2:-}"; shift 2 ;;
    *) ARGS+=("$1"); shift ;;
  esac
done
set -- "${ARGS[@]+"${ARGS[@]}"}"

# Validate any explicitly supplied slug at the input boundary (covers init and
# every command that takes --slug). Auto-resolved slugs come from directory
# basenames and are already trusted.
[[ -n "$SLUG" ]] && validate_slug "$SLUG"

resolve_session() {
  if [[ -z "$SLUG" ]]; then
    local sessions=()
    if [[ -d "$SESSION_ROOT" ]]; then
      while IFS= read -r f; do
        sessions+=("$(basename "$(dirname "$f")")")
      done < <(find "$SESSION_ROOT" -mindepth 2 -maxdepth 2 -name phase-state.md 2>/dev/null)
    fi
    case "${#sessions[@]}" in
      0) die "no active session found under $SESSION_ROOT — run 'devflow-ctl init' first" ;;
      1) SLUG="${sessions[0]}" ;;
      *) die "multiple active sessions (${sessions[*]}) — disambiguate with --slug" ;;
    esac
  fi
  STATE_FILE="$SESSION_ROOT/$SLUG/phase-state.md"
  [[ -f "$STATE_FILE" ]] || die "no phase-state.md for slug '$SLUG' at $STATE_FILE"
  head -1 "$STATE_FILE" | grep -q '^---$' \
    || die "$STATE_FILE has no YAML frontmatter — created by an older DevFlow version? Re-run 'devflow-ctl init'"
}

# ── Frontmatter primitives ────────────────────────────────────────────────────
# The frontmatter is a restricted YAML subset: flat keys, one level of nesting
# (gates:, iterations:, checkpoints:), and one list (scope:). Values are plain
# scalars — no quoting, anchors, or multi-line values.

fm_get() { # fm_get <key>  (dotted for nested, e.g. gates.confirmation)
  local key="$1"
  awk -v key="$key" '
    BEGIN { n = split(key, p, "."); infm = 0; sect = "" }
    NR == 1 && $0 == "---" { infm = 1; next }
    infm && $0 == "---"    { exit }
    !infm                  { next }
    /^[A-Za-z_][A-Za-z0-9_-]*:/ {
      k = $0; sub(/:.*/, "", k)
      if (n == 1 && k == key) { v = $0; sub(/^[^:]*:[[:space:]]*/, "", v); print v; exit }
      sect = ($0 ~ /:[[:space:]]*$/) ? k : ""
      next
    }
    n == 2 && sect == p[1] && /^  [A-Za-z_][A-Za-z0-9_-]*:/ {
      k = $0; sub(/^  /, "", k); sub(/:.*/, "", k)
      if (k == p[2]) { v = $0; sub(/^[^:]*:[[:space:]]*/, "", v); print v; exit }
    }
  ' "$STATE_FILE"
}

fm_set() { # fm_set <key> <value> — replace in place, or append (creating the section if nested)
  local key="$1" value="$2" tmp
  tmp="$(mktemp)"
  awk -v key="$key" -v val="$value" '
    BEGIN { n = split(key, p, "."); infm = 0; sect = ""; done = 0 }
    NR == 1 && $0 == "---" { infm = 1; print; next }
    infm && $0 == "---" && !closed {
      if (!done) {
        if (n == 1) print key ": " val
        else if (sect == p[1]) print "  " p[2] ": " val
        else { print p[1] ":"; print "  " p[2] ": " val }
      }
      closed = 1; infm = 0; print; next
    }
    !infm { print; next }
    /^[A-Za-z_][A-Za-z0-9_-]*:/ {
      k = $0; sub(/:.*/, "", k)
      # Leaving the target section without finding the subkey: append it now.
      if (n == 2 && sect == p[1] && k != p[1] && !done) { print "  " p[2] ": " val; done = 1 }
      if (n == 1 && k == key && !done) { print key ": " val; done = 1; sect = ""; next }
      sect = ($0 ~ /:[[:space:]]*$/) ? k : ""
      if (n == 2 && sect == p[1]) sect_seen = 1
      print; next
    }
    n == 2 && sect == p[1] && /^  [A-Za-z_][A-Za-z0-9_-]*:/ {
      k = $0; sub(/^  /, "", k); sub(/:.*/, "", k)
      if (k == p[2] && !done) { print "  " p[2] ": " val; done = 1; next }
    }
    { print }
  ' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

fm_list() { # fm_list <key> — print one list item per line
  local key="$1"
  awk -v key="$key" '
    BEGIN { infm = 0; insect = 0 }
    NR == 1 && $0 == "---" { infm = 1; next }
    infm && $0 == "---"    { exit }
    !infm                  { next }
    /^[A-Za-z_][A-Za-z0-9_-]*:/ {
      k = $0; sub(/:.*/, "", k)
      insect = (k == key)
      next
    }
    insect && /^  - / { v = $0; sub(/^  - /, "", v); print v }
  ' "$STATE_FILE"
}

fm_list_add() { # fm_list_add <key> <item> — append to a list, creating the section if missing
  local key="$1" item="$2" tmp
  tmp="$(mktemp)"
  awk -v key="$key" -v item="$item" '
    BEGIN { infm = 0; insect = 0; done = 0 }
    NR == 1 && $0 == "---" { infm = 1; print; next }
    infm && $0 == "---" {
      if (!done) { print key ":"; print "  - " item }
      infm = 0; print; next
    }
    !infm { print; next }
    /^[A-Za-z_][A-Za-z0-9_-]*:/ {
      k = $0; sub(/:.*/, "", k)
      if (insect && !done) { print "  - " item; done = 1 }
      insect = (k == key && !done)
      print; next
    }
    { print }
  ' "$STATE_FILE" > "$tmp" && mv "$tmp" "$STATE_FILE"
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_init() {
  local mode="" scope_globs=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mode)  mode="${2:-}"; shift 2 ;;
      --scope) scope_globs+=("${2:-}"); shift 2 ;;
      *) die "init: unknown argument '$1'" ;;
    esac
  done
  [[ -n "$mode" ]] || die "init: --mode is required (lifecycle|feature|refactor|bug-fix|...)"
  [[ -n "$SLUG" ]] || die "init: --slug is required"
  STATE_FILE="$SESSION_ROOT/$SLUG/phase-state.md"
  [[ -f "$STATE_FILE" ]] && die "session '$SLUG' already exists at $STATE_FILE — resume it or pick another slug"

  mkdir -p "$SESSION_ROOT/$SLUG"
  {
    echo "---"
    echo "devflow: $SCHEMA_VERSION"
    echo "slug: $SLUG"
    echo "mode: $mode"
    echo "phase: 1"
    echo "pair_mode: false"
    echo "rigor: standard"
    echo "branch: none"
    echo "locked_by: Orchestrator"
    echo "locked_since: $(now_iso)"
    echo "gates:"
    if [[ "$mode" == "lifecycle" ]]; then
      echo "  validation: pending"
      echo "  confirmation: pending"
    else
      echo "  plan_approval: pending"
    fi
    if [[ ${#scope_globs[@]} -gt 0 ]]; then
      echo "scope:"
      for g in "${scope_globs[@]}"; do echo "  - $g"; done
    fi
    echo "iterations:"
    echo "checkpoints:"
    echo "---"
    echo ""
    echo "# DevFlow Phase State"
    echo ""
    echo "> Machine-readable state lives in the frontmatter above — manage it with \`devflow-ctl\`."
    echo "> The sections below are the human-readable session log."
    echo ""
    echo "## Iteration Log"
    echo "| # | From | To | Reason |"
    echo "|---|------|----|--------|"
    echo ""
    echo "## Escalation Log"
    echo "| # | Phases | Trigger | Attempts | Root Cause | User Decision |"
    echo "|---|--------|---------|:--------:|------------|---------------|"
  } > "$STATE_FILE"
  ok "session '$SLUG' initialized (mode: $mode, lock acquired) at $STATE_FILE"
}

cmd_status() {
  resolve_session
  echo "Session:   $SLUG (schema v$(fm_get devflow))"
  echo "Mode:      $(fm_get mode)"
  echo "Phase:     $(fm_get phase)"
  echo "Branch:    $(fm_get branch)"
  echo "Pair mode: $(fm_get pair_mode)"
  echo "Rigor:     $(fm_get rigor)"
  echo "Lock:      $(fm_get locked_by) (since $(fm_get locked_since))"
  echo "Gates:"
  for g in validation confirmation plan_approval; do
    local v; v="$(fm_get "gates.$g")"
    [[ -n "$v" ]] && echo "  $g: $v"
  done
  local scope; scope="$(fm_list scope)"
  if [[ -n "$scope" ]]; then
    echo "Scope:"
    while IFS= read -r g; do echo "  - $g"; done <<< "$scope"
  else
    echo "Scope:     (not declared)"
  fi
}

cmd_phase() {
  resolve_session
  case "${1:-}" in
    get) fm_get phase ;;
    set)
      [[ "${2:-}" =~ ^[0-9]+(\.[0-9]+)?$ ]] || die "phase set: numeric phase required"
      fm_set phase "$2"
      ok "phase set to $2"
      ;;
    *) die "usage: devflow-ctl phase get|set <N>" ;;
  esac
}

gate_allowed_values() {
  case "$1" in
    validation)                 echo "pending passed blocked accepted-risks" ;;
    confirmation|plan_approval) echo "pending approved rejected" ;;
    *) return 1 ;;
  esac
}

cmd_gate() {
  resolve_session
  local action="${1:-}" gate="${2:-}" value="${3:-}"
  [[ -n "$gate" ]] || die "usage: devflow-ctl gate check|set <gate> [value]"
  gate_allowed_values "$gate" >/dev/null || die "unknown gate '$gate' (validation|confirmation|plan_approval)"
  local current; current="$(fm_get "gates.$gate")"

  case "$action" in
    check)
      [[ -n "$current" ]] || fail "gate '$gate' is not declared for this session (mode: $(fm_get mode))"
      case "$gate:$current" in
        validation:passed|validation:accepted-risks) ok "gate '$gate' is open ($current)" ;;
        confirmation:approved|plan_approval:approved) ok "gate '$gate' is open ($current)" ;;
        *) fail "gate '$gate' is CLOSED (state: $current) — do not proceed past this gate" ;;
      esac
      ;;
    set)
      [[ -n "$value" ]] || die "gate set: value required"
      local allowed; allowed="$(gate_allowed_values "$gate")"
      [[ " $allowed " == *" $value "* ]] || die "invalid value '$value' for gate '$gate' (allowed: $allowed)"
      # Transition invariants — illegal states are rejected no matter what the agent intends.
      if [[ "$gate" == "validation" && "$value" == "accepted-risks" && "$current" != "blocked" ]]; then
        die "validation can only move to 'accepted-risks' from 'blocked' (current: ${current:-unset}) — accepted-risks records a user decision over BLOCK findings"
      fi
      if [[ "$gate" == "confirmation" && "$value" == "approved" ]]; then
        local val_state; val_state="$(fm_get gates.validation)"
        if [[ -n "$val_state" && "$val_state" != "passed" && "$val_state" != "accepted-risks" ]]; then
          die "cannot approve confirmation while validation gate is '$val_state' — resolve the Validation Gate first"
        fi
      fi
      fm_set "gates.$gate" "$value"
      ok "gate '$gate': ${current:-unset} → $value"
      ;;
    *) die "usage: devflow-ctl gate check|set <gate> [value]" ;;
  esac
}

cmd_scope() {
  resolve_session
  case "${1:-}" in
    check)
      local file="${2:-}"
      [[ -n "$file" ]] || die "usage: devflow-ctl scope check <file>"
      file="${file#./}"
      # Flow Artifacts Exception (rules.md): DevFlow's own artifacts are always in scope.
      [[ "$file" == docs/devflow/* ]] && { ok "'$file' is a DevFlow artifact (always allowed)"; return; }
      local globs; globs="$(fm_list scope)"
      [[ -n "$globs" ]] || fail "no scope declared for session '$SLUG' — declare it with 'scope add' before editing files"
      while IFS= read -r glob; do
        # `**` and `*` both match across `/` in bash [[ == ]] pattern matching.
        local pattern="${glob//\*\*/*}"
        # shellcheck disable=SC2053
        if [[ "$file" == $pattern ]]; then
          ok "'$file' matches scope glob '$glob'"
          return
        fi
      done <<< "$globs"
      fail "'$file' is OUTSIDE the declared scope — ask the user for explicit approval, then 'scope add' it"
      ;;
    add)
      [[ -n "${2:-}" ]] || die "usage: devflow-ctl scope add <glob>"
      fm_list_add scope "$2"
      ok "scope extended with '$2'"
      ;;
    list) fm_list scope ;;
    *) die "usage: devflow-ctl scope check <file> | add <glob> | list" ;;
  esac
}

iterate_default_max() {
  case "$1" in
    implement_review|implement_debug) echo 3 ;;
    plan_revision|validation_brainstorm) echo 2 ;;
    *) echo 3 ;;
  esac
}

cmd_iterate() {
  resolve_session
  local loop="${1:-}"; shift || true
  [[ -n "$loop" ]] || die "usage: devflow-ctl iterate <loop> [--max <N>]"
  local max=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --max) max="${2:-}"; shift 2 ;;
      *) die "iterate: unknown argument '$1'" ;;
    esac
  done
  max="${max:-${DEVFLOW_MAX_ITERATIONS:-$(iterate_default_max "$loop")}}"
  local count; count="$(fm_get "iterations.$loop")"
  count=$(( ${count:-0} + 1 ))
  fm_set "iterations.$loop" "$count"
  if (( count > max )); then
    fail "loop '$loop' exceeded its limit ($count > $max) — STOP iterating and escalate to the user with the structured triage"
  fi
  ok "loop '$loop' iteration $count of $max"
}

cmd_lock() {
  resolve_session
  local holder since
  holder="$(fm_get locked_by)"
  since="$(fm_get locked_since)"
  case "${1:-}" in
    check)
      if [[ -z "$holder" || "$holder" == "none" ]]; then
        ok "no active lock"
        return
      fi
      local age_min=-1 epoch; epoch="$(to_epoch "$since")"
      [[ "$epoch" != 0 ]] && age_min=$(( ($(date +%s) - epoch) / 60 ))
      if (( age_min >= STALE_LOCK_MINUTES )); then
        echo "[devflow-ctl] WARN: lock held by $holder is STALE (${age_min} min old) — it may be broken after informing the user"
        return 0
      fi
      fail "session locked by $holder since $since (${age_min} min ago) — do not write to this session"
      ;;
    acquire)
      local agent="${2:-}" force="${3:-}"
      [[ -n "$agent" ]] || die "usage: devflow-ctl lock acquire <agent> [--force]"
      if [[ -n "$holder" && "$holder" != "none" && "$holder" != "$agent" && "$force" != "--force" ]]; then
        local epoch; epoch="$(to_epoch "$since")"
        local age_min=$(( ($(date +%s) - epoch) / 60 ))
        (( age_min >= STALE_LOCK_MINUTES )) \
          || fail "lock held by $holder (${age_min} min ago) — wait, or pass --force to break a stale lock"
      fi
      fm_set locked_by "$agent"
      fm_set locked_since "$(now_iso)"
      ok "lock acquired by $agent"
      ;;
    release)
      fm_set locked_by "none"
      fm_set locked_since "—"
      ok "lock released"
      ;;
    *) die "usage: devflow-ctl lock check | acquire <agent> [--force] | release" ;;
  esac
}

cmd_config() {
  resolve_session
  local action="${1:-}" key="${2:-}" value="${3:-}"
  case "$key" in
    branch|pair_mode|mode|phase|rigor) ;;
    *) die "config: key must be one of branch|pair_mode|mode|phase|rigor (gates and counters have their own commands)" ;;
  esac
  case "$action" in
    get) fm_get "$key" ;;
    set)
      [[ -n "$value" ]] || die "usage: devflow-ctl config set <key> <value>"
      if [[ "$key" == "pair_mode" && "$value" != "true" && "$value" != "false" ]]; then
        die "config: pair_mode must be 'true' or 'false'"
      fi
      if [[ "$key" == "rigor" ]]; then
        case "$value" in
          light|standard|deep|maximum) ;;
          *) die "config: rigor must be 'light', 'standard', 'deep', or 'maximum'" ;;
        esac
      fi
      fm_set "$key" "$value"
      ok "$key set to $value"
      ;;
    *) die "usage: devflow-ctl config set <key> <value> | get <key>" ;;
  esac
}

cmd_checkpoint() {
  resolve_session
  case "${1:-}" in
    set)
      [[ -n "${2:-}" && -n "${3:-}" ]] || die "usage: devflow-ctl checkpoint set <name> <sha>"
      fm_set "checkpoints.$2" "$3"
      ok "checkpoint '$2' = $3"
      ;;
    get)
      [[ -n "${2:-}" ]] || die "usage: devflow-ctl checkpoint get <name>"
      local v; v="$(fm_get "checkpoints.$2")"
      [[ -n "$v" ]] || die "checkpoint '$2' not recorded"
      echo "$v"
      ;;
    *) die "usage: devflow-ctl checkpoint set <name> <sha> | get <name>" ;;
  esac
}

# Required section patterns per artifact type (case-insensitive, matched
# against markdown headings). Kept in sync with shared/artifact-checklist.md.
artifacts_required() {
  case "$1" in
    spec)       printf '%s\n' "Digest" "Context" "Architecture" "Data Structures" "Reusability" "Test Architecture" "Risk" "Design Decisions" "Constraints" ;;
    plan)       printf '%s\n' "Digest" "File Map" "Task" "Self-Review" ;;
    review)     printf '%s\n' "Summary" "Findings" "Verdict" ;;
    validation) printf '%s\n' "Assumptions" "Standards Scan" "Contradictions" "Security" "Architecture Risks" "Alternatives" ;;
    *) return 1 ;;
  esac
}

cmd_artifacts() {
  [[ "${1:-}" == "check" ]] || die "usage: devflow-ctl artifacts check <spec|plan|review|validation> <path>"
  local type="${2:-}" path="${3:-}"
  [[ -n "$type" && -n "$path" ]] || die "usage: devflow-ctl artifacts check <type> <path>"
  [[ -f "$path" ]] || fail "artifact not found at $path — it was never saved with create_file"
  local required missing=()
  required="$(artifacts_required "$type")" || die "unknown artifact type '$type' (spec|plan|review|validation)"
  while IFS= read -r section; do
    grep -qiE "^#{1,4} .*${section}" "$path" || missing+=("$section")
  done <<< "$required"
  if [[ ${#missing[@]} -gt 0 ]]; then
    fail "artifact '$path' is missing required section(s): ${missing[*]} — complete it before proceeding (see shared/artifact-checklist.md)"
  fi
  ok "artifact '$path' has all required $type sections"
}

# ── Environment capabilities ──────────────────────────────────────────────────
# Reads from .devflow-environment marker file (written by install.sh).
# Falls back to "unknown" for all primitives if the file is absent.

ENV_FILE=""
_detect_env_file() {
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  ENV_FILE="${script_dir}/../.devflow-environment"
}

cmd_capabilities() {
  _detect_env_file
  local action="${1:-print}"
  case "$action" in
    get)
      local key="${2:-}"
      [[ -n "$key" ]] || die "usage: devflow-ctl capabilities get <key> (subagents|vision|terminal|filesystem|profile)"
      local value="unknown"
      if [[ -f "$ENV_FILE" ]]; then
        value="$(grep -E "^${key}:" "$ENV_FILE" 2>/dev/null | head -1 | sed "s/^${key}: *//")"
        [[ -n "$value" ]] || value="unknown"
      fi
      echo "$value"
      ;;
    print)
      if [[ -f "$ENV_FILE" ]]; then
        while IFS=: read -r k v; do
          v="${v#"${v%%[![:space:]]*}"}"
          [[ -n "$k" ]] && echo "$k: $v"
        done < "$ENV_FILE"
      else
        echo "profile: unknown"
        echo "subagents: unknown"
        echo "vision: unknown"
        echo "terminal: unknown"
        echo "filesystem: unknown"
      fi
      ;;
    *)
      die "usage: devflow-ctl capabilities [get <key>]"
      ;;
  esac
}

# ── Knowledge base ────────────────────────────────────────────────────────────
# The knowledge base lives at docs/devflow/knowledge-base/learnings.md.
# Entries are ### headings under ## Cycle History.

KNOWLEDGE_FILE="${DEVFLOW_KNOWLEDGE_FILE:-docs/devflow/knowledge-base/learnings.md}"

cmd_knowledge() {
  case "${1:-}" in
    list)
      if [[ ! -f "$KNOWLEDGE_FILE" ]]; then
        echo "Knowledge base not found at $KNOWLEDGE_FILE"
        echo "Run '/devflow-templates bootstrap-knowledge' to create it from historical artifacts."
        exit 0
      fi
      local entries
      entries="$(grep -c '^### ' "$KNOWLEDGE_FILE" 2>/dev/null || echo 0)"
      echo "Knowledge base: $KNOWLEDGE_FILE"
      echo "Entries: $entries"
      echo ""
      grep '^### ' "$KNOWLEDGE_FILE" 2>/dev/null || echo "(no entries yet)"
      ;;
    add)
      local entry_file="${2:-}"
      [[ -n "$entry_file" ]] || die "usage: devflow-ctl knowledge add <file>"
      [[ -f "$entry_file" ]] || die "knowledge add: file not found at $entry_file"
      # Ensure KB directory exists
      mkdir -p "$(dirname "$KNOWLEDGE_FILE")"
      # If KB doesn't exist, create it with the header
      if [[ ! -f "$KNOWLEDGE_FILE" ]]; then
        echo "# DevFlow Knowledge Base" > "$KNOWLEDGE_FILE"
        echo "" >> "$KNOWLEDGE_FILE"
        echo "## By Topic" >> "$KNOWLEDGE_FILE"
        echo "" >> "$KNOWLEDGE_FILE"
        echo "## Cycle History" >> "$KNOWLEDGE_FILE"
        echo "" >> "$KNOWLEDGE_FILE"
      fi
      # Append the entry file content to the KB
      echo "" >> "$KNOWLEDGE_FILE"
      cat "$entry_file" >> "$KNOWLEDGE_FILE"
      ok "knowledge entry from $entry_file appended to $KNOWLEDGE_FILE"
      ;;
    *)
      die "usage: devflow-ctl knowledge list | add <file>"
      ;;
  esac
}

# ── Sessions list ─────────────────────────────────────────────────────────────
# Lists all active DevFlow sessions with phase, mode, and lock state.

cmd_sessions() {
  if [[ ! -d "$SESSION_ROOT" ]]; then
    echo "No sessions found ($SESSION_ROOT does not exist)"
    exit 0
  fi
  local found=0
  while IFS= read -r -d '' statefile; do
    local slug phase mode lock locked_by
    slug="$(basename "$(dirname "$statefile")")"
    # Read frontmatter fields without resolving a single session
    phase="$(awk '/^phase:/{print $2;exit}' "$statefile" 2>/dev/null || echo "?")"
    mode="$(awk '/^mode:/{print $2;exit}' "$statefile" 2>/dev/null || echo "?")"
    locked_by="$(awk '/^locked_by:/{sub(/^locked_by: */,"");print;exit}' "$statefile" 2>/dev/null || echo "?")"
    rigor="$(awk '/^rigor:/{print $2;exit}' "$statefile" 2>/dev/null || echo "?")"
    if [[ "$locked_by" == "none" || -z "$locked_by" ]]; then
      lock="unlocked"
    else
      lock="locked by $locked_by"
    fi
    printf "%-20s  Phase: %-6s  Mode: %-10s  Rigor: %-8s  %s\n" "$slug" "$phase" "$mode" "$rigor" "$lock"
    found=1
  done < <(find "$SESSION_ROOT" -mindepth 2 -maxdepth 2 -name phase-state.md -print0 2>/dev/null)
  if [[ $found -eq 0 ]]; then
    echo "No active sessions found"
  fi
}

# ── Clean stale sessions ──────────────────────────────────────────────────────
# Removes sessions that are unlocked or stale (locked >30 min without activity).

cmd_clean() {
  if [[ ! -d "$SESSION_ROOT" ]]; then
    echo "No sessions to clean ($SESSION_ROOT does not exist)"
    exit 0
  fi
  local force=false removed=0
  [[ "${1:-}" == "--force" ]] && force=true
  while IFS= read -r -d '' statefile; do
    local slug locked_by locked_since epoch_now epoch_lock age
    slug="$(basename "$(dirname "$statefile")")"
    locked_by="$(awk '/^locked_by:/{sub(/^locked_by: */,"");print;exit}' "$statefile" 2>/dev/null || echo "none")"
    if $force; then
      rm -rf "$SESSION_ROOT/$slug"
      echo "  removed: $slug (--force)"
      ((removed++)) || true
      continue
    fi
    if [[ "$locked_by" == "none" || -z "$locked_by" ]]; then
      rm -rf "$SESSION_ROOT/$slug"
      echo "  removed: $slug (unlocked)"
      ((removed++)) || true
      continue
    fi
    # Check stale lock
    locked_since="$(awk '/^locked_since:/{sub(/^locked_since: */,"");print;exit}' "$statefile" 2>/dev/null || echo "")"
    epoch_now="$(date -u +%s)"
    epoch_lock="$(to_epoch "$locked_since")"
    age=$(( (epoch_now - epoch_lock) / 60 ))
    if [[ $age -ge $STALE_LOCK_MINUTES ]]; then
      rm -rf "$SESSION_ROOT/$slug"
      echo "  removed: $slug (stale lock, ${age} min)"
      ((removed++)) || true
    fi
  done < <(find "$SESSION_ROOT" -mindepth 2 -maxdepth 2 -name phase-state.md -print0 2>/dev/null)
  if [[ $removed -eq 0 ]]; then
    ok "no stale sessions to clean"
  else
    ok "cleaned $removed session(s)"
  fi
}

# ── Security scanning (deterministic) ─────────────────────────────────────────
# Move vulnerability detection from "the LLM judges" to "a tool verifies". Each
# sub-scanner is best-effort: it runs a real scanner when present, falls back to
# a built-in detector where one exists, and skips gracefully (without failing)
# when neither applies — the same graceful-degradation contract as capabilities.
# The result is incontestable: the LLM's job shifts from FINDING vulnerabilities
# (unreliable) to FIXING the ones a tool deterministically reports.

SCAN_FINDINGS=0   # accumulated across sub-scanners in one invocation

# Files to scan: tracked text files in a git repo, else a filtered find.
_scan_files() {
  if [[ -d .git ]] && command -v git >/dev/null 2>&1; then
    git ls-files 2>/dev/null
  else
    find . -type f -not -path './.git/*' -not -path '*/node_modules/*' \
      -not -name '.devflow-environment' 2>/dev/null | sed 's|^\./||'
  fi
}

# Secrets: gitleaks if present, else a built-in high-signal regex detector.
scan_secrets() {
  echo "== scan: secrets =="
  if command -v gitleaks >/dev/null 2>&1; then
    if gitleaks detect --no-banner --redact -r /tmp/devflow-gitleaks.json >/dev/null 2>&1; then
      echo "  clean (gitleaks)"; return 0
    fi
    local n; n="$(jq 'length' /tmp/devflow-gitleaks.json 2>/dev/null || echo '?')"
    echo "  [HIGH] gitleaks reported $n potential secret(s) — see /tmp/devflow-gitleaks.json"
    SCAN_FINDINGS=$(( SCAN_FINDINGS + 1 )); return 1
  fi

  # Built-in fallback — high-signal, low-false-positive patterns.
  local -a rules=(
    "AWS access key|AKIA[0-9A-Z]{16}"
    "Private key block|-----BEGIN ([A-Z]+ )?PRIVATE KEY-----"
    "GitHub token|ghp_[A-Za-z0-9]{36}"
    "Slack token|xox[baprs]-[A-Za-z0-9-]{10,}"
    "Google API key|AIza[0-9A-Za-z_-]{35}"
    "Hardcoded secret assignment|(api[_-]?key|secret|token|passwd|password)['\"]?[[:space:]]*[:=][[:space:]]*['\"][A-Za-z0-9_-]{16,}['\"]"
  )
  local found=0 f rule name re lineno
  while IFS= read -r f; do
    [[ -f "$f" ]] || continue
    for rule in "${rules[@]}"; do
      name="${rule%%|*}"; re="${rule#*|}"
      while IFS= read -r lineno; do
        [[ -n "$lineno" ]] || continue
        echo "  [HIGH] $f:$lineno — $name"
        found=$(( found + 1 ))
      done < <(grep -nIE -e "$re" "$f" 2>/dev/null | cut -d: -f1)
    done
  done < <(_scan_files)

  if (( found > 0 )); then
    SCAN_FINDINGS=$(( SCAN_FINDINGS + found ))
    echo "  $found potential secret(s) (built-in detector; install gitleaks for deeper coverage)"
    return 1
  fi
  echo "  clean (built-in detector; install gitleaks for deeper coverage)"
  return 0
}

# SCA: known CVEs in dependencies (npm audit for Node; skips otherwise).
scan_sca() {
  echo "== scan: dependencies (SCA) =="
  if [[ -f package.json ]] && command -v npm >/dev/null 2>&1; then
    local out crit hi
    out="$(npm audit --audit-level=high --json 2>/dev/null || true)"
    if [[ -z "$out" ]]; then
      echo "  skipped: npm audit produced no output (offline or no lockfile)"; return 0
    fi
    crit="$(printf '%s' "$out" | jq -r '.metadata.vulnerabilities.critical // 0' 2>/dev/null || echo 0)"
    hi="$(printf '%s' "$out" | jq -r '.metadata.vulnerabilities.high // 0' 2>/dev/null || echo 0)"
    crit="${crit:-0}"; hi="${hi:-0}"
    if (( crit + hi > 0 )); then
      echo "  [${crit} critical, ${hi} high] npm dependencies — run 'npm audit' for detail"
      SCAN_FINDINGS=$(( SCAN_FINDINGS + crit + hi )); return 1
    fi
    echo "  clean (no high/critical npm vulnerabilities)"; return 0
  fi
  echo "  skipped: no supported manifest found (Node package.json)"; return 0
}

# SAST: dangerous code patterns (injection, unsafe sinks) via semgrep.
# No built-in regex fallback by design — a regex SAST produces false BLOCKs,
# the exact noise this deterministic approach exists to avoid. SAST needs a
# real engine, so without semgrep it skips and the gap is reported honestly.
scan_sast() {
  echo "== scan: code patterns (SAST) =="
  if command -v semgrep >/dev/null 2>&1; then
    local out n
    out="$(semgrep --config auto --json --quiet 2>/dev/null || true)"
    if [[ -z "$out" ]]; then
      echo "  skipped: semgrep produced no output (offline rule fetch?)"; return 0
    fi
    n="$(printf '%s' "$out" | jq '[.results[] | select(.extra.severity=="ERROR")] | length' 2>/dev/null || echo 0)"
    n="${n:-0}"
    if (( n > 0 )); then
      echo "  [$n ERROR-severity finding(s)] semgrep — run 'semgrep --config auto' for detail"
      SCAN_FINDINGS=$(( SCAN_FINDINGS + n )); return 1
    fi
    echo "  clean (no ERROR-severity semgrep findings)"; return 0
  fi
  echo "  skipped: semgrep not installed (install for SAST coverage: pipx install semgrep)"; return 0
}

cmd_scan() {
  local kind="${1:-all}"
  SCAN_FINDINGS=0
  case "$kind" in
    secrets)  scan_secrets || true ;;
    sca|deps) scan_sca || true ;;
    sast)     scan_sast || true ;;
    all)      scan_secrets || true; echo; scan_sca || true; echo; scan_sast || true ;;
    *) die "usage: devflow-ctl scan [secrets|sca|sast|all]" ;;
  esac
  echo
  if (( SCAN_FINDINGS > 0 )); then
    echo "[devflow-ctl] FAIL: scan found $SCAN_FINDINGS potential issue(s) — remediate before proceeding" >&2
    exit 1
  fi
  ok "scan: clean (no findings from the scanners that ran)"
}

# ── Dispatch ──────────────────────────────────────────────────────────────────

CMD="${1:-help}"; shift || true
case "$CMD" in
  init)       cmd_init "$@" ;;
  status)     cmd_status "$@" ;;
  phase)      cmd_phase "$@" ;;
  gate)       cmd_gate "$@" ;;
  scope)      cmd_scope "$@" ;;
  iterate)    cmd_iterate "$@" ;;
  lock)       cmd_lock "$@" ;;
  config)     cmd_config "$@" ;;
  checkpoint) cmd_checkpoint "$@" ;;
  artifacts)  cmd_artifacts "$@" ;;
  capabilities) cmd_capabilities "$@" ;;
  knowledge)  cmd_knowledge "$@" ;;
  sessions)   cmd_sessions "$@" ;;
  clean)      cmd_clean "$@" ;;
  scan)       cmd_scan "$@" ;;
  version)    echo "devflow-ctl schema v$SCHEMA_VERSION" ;;
  help|--help|-h) sed -n '2,35p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) die "unknown command '$CMD' — run 'devflow-ctl help'" ;;
esac
