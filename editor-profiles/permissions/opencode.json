      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "tree *": "allow",
      "du *": "allow",
      "stat *": "allow",
      "file *": "allow",
      "which *": "allow",
      "pwd": "allow",
      "diff *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "awk *": "allow",
      "sed *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "test *": "allow",
      "npm run *": "allow",
      "npm test*": "allow",
      "npm ci*": "allow",
      "npx *": "allow",
      "pnpm *": "allow",
      "yarn *": "allow",
