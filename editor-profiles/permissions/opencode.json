{
  "permission": {
    "bash": {
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git commit --no-verify*": "deny",
      "rm *": "ask",
      "rmdir *": "ask",
      "git push*": "ask",
      "git reset --hard*": "ask",
      "git clean*": "ask",
      "git rebase*": "ask",
      "git commit --amend*": "ask",
      "git cherry-pick*": "ask",
      "sudo *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "kill *": "ask",
      "pkill *": "ask",
      "killall *": "ask",
      "npm install*": "ask",
      "yarn add*": "ask",
      "pip install*": "ask",
      "devflow-ctl *": "allow",
      "$SKILLS_DIR/shared/bin/devflow-ctl *": "allow",
      "bash $SKILLS_DIR/shared/bin/devflow-ctl *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "git rev-parse *": "allow",
      "git status*": "allow",
